# Personal stack profiles are private — never commit a real one.
# Only the example template is tracked; the router loads profiles/*.md, and the
# template's .template suffix keeps it from being auto-loaded.
profiles/*
!profiles/example.md.template

# Private internal-name denylist (check-invariants.sh check 3) — a tracked
# copy would disclose the names it exists to suppress. CI uses the
# SOTA_DENYLIST repository secret instead.
.denylist.local

# OS / editor cruft
.DS_Store
*.swp
*~

# Local secrets (OPENROUTER_API_KEY etc.) — never commit
.env
