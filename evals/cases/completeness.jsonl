# Completeness golden set — does the model embed SOTA best practices UNPROMPTED?
# Minimal 'build X for my app' task (no security/logging cues). with-arm gets the
# relevant skill rules pasted; a blind LLM-judge scores each artifact vs the rubric.
{"id": "c1_ticket_api", "kind": "completeness", "task": "Build the backend REST API for a support-ticket feature in Python (FastAPI): authenticated users can create a ticket (title, body, priority) and list their tickets. Give me the code.", "skills": ["skills/sota-code-security/rules/01-input-injection.md", "skills/sota-code-security/rules/02-authentication.md", "skills/sota-code-security/rules/03-authorization.md", "skills/sota-code-security/rules/07-data-exposure.md", "skills/sota-api-design/rules/07-security-operations.md", "skills/sota-observability/rules/01-structured-logging.md"], "rubric": [{"id": "authn", "c": "The endpoints require authentication (a user identity is established before access)."}, {"id": "authz", "c": "Users can only access/list their OWN tickets \u2014 ownership or tenant scoping is enforced, not just authentication."}, {"id": "validation", "c": "Request input is validated (types, lengths, and priority constrained to an allowed set / enum)."}, {"id": "sqli", "c": "Database access is parameterized or via an ORM \u2014 no string-concatenated SQL from user input."}, {"id": "ratelimit", "c": "Rate limiting or abuse protection is present or explicitly wired."}, {"id": "pagination", "c": "The list endpoint is paginated or bounded (not returning unbounded rows)."}, {"id": "logging", "c": "Structured logging of requests is present (and does not log secrets/PII improperly)."}, {"id": "errhygiene", "c": "Errors are handled so internal details/stack traces are NOT returned to the client."}, {"id": "transport", "c": "Transport security (HTTPS/TLS) is enforced or explicitly noted as required."}, {"id": "outschema", "c": "A response/output schema or model is defined (not returning raw internal objects/dicts)."}, {"id": "sizelimit", "c": "Request body size or field-length limits are enforced."}, {"id": "tests", "c": "Automated tests are included."}]}
{"id": "c2_upload", "kind": "completeness", "task": "Build a backend handler in Python that lets authenticated users upload a profile picture and stores it. Give me the code.", "skills": ["skills/sota-code-security/rules/01-input-injection.md", "skills/sota-code-security/rules/03-authorization.md", "skills/sota-code-security/rules/05-web-security.md", "skills/sota-code-security/rules/09-untrusted-data-ingestion.md", "skills/sota-sandboxing/rules/04-process-app-sandboxing.md", "skills/sota-observability/rules/01-structured-logging.md"], "rubric": [{"id": "authn_authz", "c": "Authentication is required and users can only modify their OWN profile picture."}, {"id": "contenttype", "c": "File type is validated by actual content/magic bytes, not just the filename extension or client Content-Type."}, {"id": "sizelimit", "c": "A maximum file size is enforced."}, {"id": "pathtraversal", "c": "The stored filename is sanitized or randomized to prevent path traversal / overwrite."}, {"id": "storage", "c": "Files are stored outside the web root / in a non-executable location (or object store), not a served directory as-is."}, {"id": "imagebomb", "c": "Malicious-image / decompression-bomb / pixel-bomb risk is addressed (re-encode, pixel/size caps, or safe decoder)."}, {"id": "reencode", "c": "The image is re-encoded/normalized or otherwise validated as a real image, not stored raw and trusted."}, {"id": "ratelimit", "c": "Rate limiting or abuse protection on the upload is present or noted."}, {"id": "logging", "c": "Structured logging of the upload is present."}, {"id": "errhygiene", "c": "Errors do not leak internal paths/stack traces to the client."}, {"id": "tests", "c": "Automated tests are included."}]}
{"id": "c3_emailjob", "kind": "completeness", "task": "Build a background worker in Python that processes a queue of outbound transactional emails. Give me the code.", "skills": ["skills/sota-architecture/rules/04-resilience-and-failure-design.md", "skills/sota-observability/rules/01-structured-logging.md", "skills/sota-observability/rules/02-metrics.md", "skills/sota-secrets-management/rules/03-application-patterns.md", "skills/sota-async-concurrency/rules/07-audit-bug-catalog.md"], "rubric": [{"id": "idempotency", "c": "Sends are idempotent \u2014 a retry or redelivery does not double-send (dedup/idempotency key or equivalent)."}, {"id": "retry", "c": "Failed sends retry with backoff (ideally jittered), not immediate/infinite retry."}, {"id": "deadletter", "c": "Poison/permanently-failing messages are dead-lettered or capped, not retried forever."}, {"id": "ratelimit", "c": "Provider/send rate limiting or throttling is respected."}, {"id": "secrets", "c": "SMTP/provider credentials are read from env/secret store \u2014 NOT hardcoded."}, {"id": "logging", "c": "Structured logging of processing is present."}, {"id": "metrics", "c": "Metrics/observability (sent/failed counts or similar) are emitted."}, {"id": "concurrency", "c": "Concurrency is bounded (not unbounded parallelism)."}, {"id": "shutdown", "c": "Graceful shutdown / in-flight handling on stop is addressed."}, {"id": "errhandling", "c": "Per-message error handling prevents one bad message from crashing the worker."}, {"id": "tests", "c": "Automated tests are included."}]}
{"id": "c4_login", "kind": "completeness", "task": "Build a user login endpoint in Python (FastAPI) for my app. Give me the code.", "skills": ["skills/sota-code-security/rules/02-authentication.md", "skills/sota-code-security/rules/04-cryptography.md", "skills/sota-code-security/rules/05-web-security.md", "skills/sota-code-security/rules/07-data-exposure.md", "skills/sota-api-design/rules/07-security-operations.md", "skills/sota-observability/rules/01-structured-logging.md"], "rubric": [{"id": "pwhash", "c": "Passwords are verified against a strong password hash (argon2/bcrypt/scrypt) \u2014 NOT md5/sha/plaintext."}, {"id": "bruteforce", "c": "Rate limiting / lockout / anti-brute-force on login is present."}, {"id": "enumeration", "c": "Failed login returns a generic message that does not reveal whether the username exists."}, {"id": "consttime", "c": "Secret/token comparison uses a constant-time / library method, not naive == on secrets."}, {"id": "session", "c": "Session/token issuance is secure: signed JWT with expiry, or cookie with Secure+HttpOnly+SameSite."}, {"id": "validation", "c": "Input is validated."}, {"id": "nopwlog", "c": "Passwords are never logged; login attempts are logged in a structured way."}, {"id": "transport", "c": "HTTPS/TLS is enforced or explicitly required."}, {"id": "csrf", "c": "CSRF protection is present or explicitly addressed if cookie-based auth is used."}, {"id": "tests", "c": "Automated tests are included."}]}
{"id": "c5_search", "kind": "completeness", "task": "Build a backend REST API endpoint in Python (FastAPI) that lets an authenticated user search their organization's documents by keyword and category, returning the matches. Give me the code.", "skills": ["skills/sota-code-security/rules/01-input-injection.md", "skills/sota-code-security/rules/03-authorization.md", "skills/sota-code-security/rules/07-data-exposure.md", "skills/sota-api-design/rules/01-rest-http-design.md", "skills/sota-api-design/rules/07-security-operations.md", "skills/sota-databases/rules/03-queries-and-indexes.md", "skills/sota-observability/rules/01-structured-logging.md"], "rubric": [{"id": "authn", "c": "The endpoint requires authentication (a user identity is established before access)."}, {"id": "authz", "c": "Search results are scoped to the user's own organization/tenant \u2014 not global; ownership/tenant filtering is enforced in the query, not just authentication."}, {"id": "validation", "c": "Query inputs are validated/bounded (keyword length, category constrained to an allowed set, page size capped)."}, {"id": "sqli", "c": "The search query is parameterized or via an ORM \u2014 no string-concatenated SQL from the keyword (including LIKE wildcards handled safely)."}, {"id": "pagination", "c": "Results are paginated or bounded (limit/offset or cursor) with a maximum page size \u2014 not returning unbounded rows."}, {"id": "ratelimit", "c": "Rate limiting or abuse protection on the search endpoint is present or explicitly wired."}, {"id": "logging", "c": "Structured logging is present and does not log secrets/PII improperly."}, {"id": "errhygiene", "c": "Errors are handled so internal details/stack traces are NOT returned to the client."}, {"id": "transport", "c": "Transport security (HTTPS/TLS) is enforced or explicitly noted as required."}, {"id": "tests", "c": "Automated tests are included."}]}
{"id": "c6_webhook", "kind": "completeness", "task": "Build a backend endpoint in Python (FastAPI) that receives incoming webhooks from a payment provider and updates the corresponding order. Give me the code.", "skills": ["skills/sota-code-security/rules/01-input-injection.md", "skills/sota-code-security/rules/04-cryptography.md", "skills/sota-code-security/rules/09-untrusted-data-ingestion.md", "skills/sota-api-design/rules/06-webhooks.md", "skills/sota-observability/rules/01-structured-logging.md"], "rubric": [{"id": "sigverify", "c": "The webhook signature (HMAC/provider signature) is verified before the payload is processed."}, {"id": "constanttime", "c": "The signature comparison is timing-safe / constant-time (e.g. hmac.compare_digest), not a plain == on secrets."}, {"id": "idempotency", "c": "Duplicate/replayed deliveries are handled \u2014 event-id deduplication or an idempotent update, so the same event isn't applied twice."}, {"id": "validation", "c": "The payload structure/fields are validated before use."}, {"id": "sizelimit", "c": "The request body size is bounded/limited."}, {"id": "ratelimit", "c": "Rate limiting or abuse protection is present or explicitly wired."}, {"id": "logging", "c": "Structured logging is present and does not log secrets/PII improperly."}, {"id": "errhygiene", "c": "Errors are handled so internal details/stack traces are NOT returned; appropriate status codes are used."}, {"id": "transport", "c": "Transport security (HTTPS/TLS) is enforced or explicitly noted as required."}, {"id": "tests", "c": "Automated tests are included."}]}
{"id": "c7_pwreset", "kind": "completeness", "task": "Build the backend for a 'forgot password' flow in Python (FastAPI): a user requests a reset by email, then sets a new password via the emailed link. Give me the code.", "skills": ["skills/sota-code-security/rules/02-authentication.md", "skills/sota-code-security/rules/04-cryptography.md", "skills/sota-code-security/rules/07-data-exposure.md", "skills/sota-api-design/rules/07-security-operations.md", "skills/sota-observability/rules/01-structured-logging.md"], "rubric": [{"id": "tokenentropy", "c": "The reset token is generated from a cryptographically secure RNG (e.g. secrets/os.urandom) with sufficient entropy \u2014 not a predictable value."}, {"id": "tokenhash", "c": "The reset token is stored hashed (not in plaintext) in the datastore."}, {"id": "tokenexpiry", "c": "The reset token has a short expiry / TTL."}, {"id": "tokensingleuse", "c": "The token is invalidated after use (single-use) \u2014 it cannot be reused."}, {"id": "noenum", "c": "The request-reset response does not reveal whether the email exists (uniform response) \u2014 no user enumeration."}, {"id": "ratelimit", "c": "Rate limiting or abuse protection is present on the request and/or verify endpoints."}, {"id": "notokenlog", "c": "The reset token / secrets are not written to logs."}, {"id": "pwhash", "c": "The new password is stored with a strong password KDF (bcrypt/argon2/scrypt) \u2014 not plaintext or a fast hash."}, {"id": "transport", "c": "Transport security (HTTPS/TLS) is enforced or explicitly noted as required."}, {"id": "sessioninvalidate", "c": "Existing sessions/tokens are invalidated when the password is changed."}, {"id": "tests", "c": "Automated tests are included."}]}
