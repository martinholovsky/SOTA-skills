{"id": "g1_ticket_api", "kind": "completeness", "task": "Build a Go HTTP API (net/http) where authenticated users can create a support ticket (title, body) and list their own tickets. Give me the code.", "skills": ["skills/sota-golang/rules/04-http-services.md", "skills/sota-golang/rules/05-security.md", "skills/sota-code-security/rules/01-input-injection.md", "skills/sota-code-security/rules/02-authentication.md", "skills/sota-code-security/rules/03-authorization.md", "skills/sota-api-design/rules/07-security-operations.md", "skills/sota-testing/rules/09-security-testing.md"], "rubric": [{"id": "authn", "c": "Requests require authentication (a user identity is established before access)."}, {"id": "authz", "c": "Users can only list/access their OWN tickets \u2014 ownership/tenant scoping enforced, not just authn."}, {"id": "validation", "c": "Request input is validated (types, lengths, required fields)."}, {"id": "injection", "c": "DB access is parameterized / uses placeholders \u2014 no string-concatenated SQL from user input."}, {"id": "ratelimit", "c": "Rate limiting or abuse protection is present or explicitly wired."}, {"id": "transport", "c": "TLS/HTTPS is enforced or explicitly required (e.g. server TLS, HSTS, or noted)."}, {"id": "timeouts", "c": "Server/request timeouts are set (ReadTimeout/WriteTimeout or context deadlines) \u2014 no unbounded handlers."}, {"id": "logging", "c": "Structured logging is present and does not log secrets/PII."}, {"id": "errhygiene", "c": "Errors are handled so internal details/stack traces are NOT returned to the client."}, {"id": "tests", "c": "Automated tests are included."}]}
{"id": "g2_webhook", "kind": "completeness", "task": "Build a Go HTTP handler that receives an incoming webhook from a payment provider and updates the corresponding order. Give me the code.", "skills": ["skills/sota-golang/rules/04-http-services.md", "skills/sota-golang/rules/05-security.md", "skills/sota-code-security/rules/01-input-injection.md", "skills/sota-code-security/rules/02-authentication.md", "skills/sota-code-security/rules/03-authorization.md", "skills/sota-api-design/rules/07-security-operations.md", "skills/sota-testing/rules/09-security-testing.md"], "rubric": [{"id": "sigverify", "c": "The webhook signature (HMAC/provider signature) is verified before the payload is processed."}, {"id": "consttime", "c": "Signature comparison is constant-time (hmac.Equal / subtle), not a plain == on secrets."}, {"id": "idempotency", "c": "Duplicate/replayed deliveries are handled (event-id dedup or idempotent update)."}, {"id": "validation", "c": "The payload structure/fields are validated before use."}, {"id": "sizelimit", "c": "The request body size is bounded (http.MaxBytesReader or similar)."}, {"id": "ratelimit", "c": "Rate limiting or abuse protection is present or noted."}, {"id": "timeouts", "c": "Server/request timeouts or context deadlines are set."}, {"id": "logging", "c": "Structured logging present; secrets not logged."}, {"id": "errhygiene", "c": "Errors handled without leaking internals; appropriate status codes."}, {"id": "tests", "c": "Automated tests are included."}]}
{"id": "g3_login", "kind": "completeness", "task": "Build a user login endpoint in Go (net/http) for my app. Give me the code.", "skills": ["skills/sota-golang/rules/04-http-services.md", "skills/sota-golang/rules/05-security.md", "skills/sota-code-security/rules/01-input-injection.md", "skills/sota-code-security/rules/02-authentication.md", "skills/sota-code-security/rules/03-authorization.md", "skills/sota-api-design/rules/07-security-operations.md", "skills/sota-testing/rules/09-security-testing.md"], "rubric": [{"id": "pwhash", "c": "Passwords verified against a strong KDF (argon2/bcrypt/scrypt) \u2014 not md5/sha/plaintext."}, {"id": "bruteforce", "c": "Rate limiting / lockout / anti-brute-force on login is present."}, {"id": "enumeration", "c": "Failed login returns a generic message not revealing whether the user exists."}, {"id": "consttime", "c": "Secret/token comparison uses constant-time compare, not naive ==."}, {"id": "session", "c": "Session/token issuance is secure (signed JWT w/ expiry, or Secure+HttpOnly+SameSite cookie)."}, {"id": "validation", "c": "Input is validated."}, {"id": "nopwlog", "c": "Passwords are never logged; attempts logged structurally."}, {"id": "transport", "c": "TLS/HTTPS enforced or explicitly required."}, {"id": "timeouts", "c": "Server/request timeouts are set."}, {"id": "tests", "c": "Automated tests are included."}]}
