# Silent-control-failure golden set — a control that LOOKS enabled and does nothing.
# Distinct from cases/audit*.jsonl: there is no classic vulnerability here. The code
# is not wrong, it is INERT — a broken system and a working one look identical from
# outside. Tests sota-code-security rules/10.
#
# 13 positive cases (one per hiding place) + 2 NEGATIVE controls (sf14/sf15) whose
# expect is ["not-silent"]: the control fails loudly, so flagging it is the error.
# The negatives exist because a model that answers "silent no-op" to everything
# would otherwise score 1.00. Languages are mixed on purpose (the breadth run
# showed domain/language effects are real).
{"id": "sf01", "kind": "silent", "language": "python", "snippet": "class MalwareScanner:\n    def __init__(self, model_dir: Path):\n        # model_dir is populated by an init container at boot\n        self.enabled = model_dir.is_dir()\n        self.model_dir = model_dir\n\n    def scan(self, blob: bytes) -> list[str]:\n        if not self.enabled:\n            return []\n        return _predict(self.model_dir, blob)\n\n# startup: log.info('scanner ENABLED=%s', scanner.enabled)", "expect": ["weak-existence-check"], "reference": "Presence/enablement is decided by model_dir.is_dir() — an empty or partially-populated directory sets enabled=True, so scan() reports no findings while looking enabled. The check must assert on the loaded artifact, not the path."}
{"id": "sf02", "kind": "silent", "language": "python", "snippet": "try:\n    import clamd\nexcept ImportError:\n    clamd = None\n\ndef scan_upload(data: bytes) -> dict:\n    if clamd is None:\n        return {\"clean\": True}\n    return clamd.ClamdUnixSocket().instream(io.BytesIO(data))\n\n# pyproject.toml: clamd is under [project.optional-dependencies].dev\n# Dockerfile: RUN pip install --no-cache-dir .", "expect": ["optional-dependency-degradation"], "reference": "clamd is an OPTIONAL dependency absent from the shipped image (it is a dev extra), so scan_upload returns {'clean': True} for every upload — the malware scan silently never runs and 'clean' is indistinguishable from a real clean scan."}
{"id": "sf03", "kind": "silent", "language": "python", "snippet": "def load_waf(path: str) -> \"Waf\":\n    doc = yaml.safe_load(open(path)) or {}\n    rules = [compile_rule(r) for r in doc.get(\"rules\", [])]\n    log.info(\"WAF ENABLED with %d rules\", len(rules))\n    return Waf(rules)\n\nclass Waf:\n    def blocks(self, req) -> bool:\n        return any(r.match(req) for r in self.rules)\n\n# shipped config/waf.example.yaml contains only commented-out rules", "expect": ["empty-ruleset-loaded"], "reference": "A config with zero rules loads successfully and logs 'WAF ENABLED with 0 rules'; blocks() then returns False for everything. The shipped example config has only commented-out rules, so deploying it verbatim yields a WAF that blocks nothing."}
{"id": "sf04", "kind": "silent", "language": "go", "snippet": "func Authorize(ctx context.Context, principal, resource string) bool {\n\tallowed, err := policyEngine.Check(ctx, principal, resource)\n\tif err != nil {\n\t\treturn true // don't block traffic on a policy-engine blip\n\t}\n\treturn allowed\n}", "expect": ["swallowed-enforcement-exception"], "reference": "The policy-engine error path returns true (allow) — authorization fails OPEN, and nothing logs or meters it, so a permanently broken policy engine looks identical to a permissive policy."}
{"id": "sf05", "kind": "silent", "language": "python", "snippet": "# settings.py\nDEBUG = os.getenv(\"DEBUG\") == \"1\"\n\"\"\"DEBUG: enable verbose request logging and the /__stats endpoint.\"\"\"\n\n# webhooks.py\ndef handle(req):\n    if not settings.DEBUG:\n        verify_signature(req)\n    return process(req.json)", "expect": ["overloaded-flag"], "reference": "The DEBUG flag is documented as verbose logging + a stats endpoint, but it is also used to skip webhook signature verification — one boolean gating a security control it was never scoped to."}
{"id": "sf06", "kind": "silent", "language": "python", "snippet": "MAX_INSPECT = 1 << 20\n\ndef inspect(body: bytes) -> Verdict:\n    if not body or len(body) > MAX_INSPECT:\n        return Verdict.ALLOW\n    return dlp_engine.inspect(body)\n\n# called from the outbound-email path; body is attacker-influenced", "expect": ["early-return-bypass"], "reference": "The size/emptiness guard returns ALLOW before the DLP engine runs, and an attacker controls the body size — padding past MAX_INSPECT deliberately bypasses inspection entirely."}
{"id": "sf07", "kind": "silent", "language": "javascript", "snippet": "async function handleUpload(req, res) {\n  const payload = await readAll(req);\n  const verdict = await scanner.scan(payload.slice(0, 8192));\n  if (verdict.clean) {\n    await store(payload);            // the WHOLE payload is stored\n    return res.sendStatus(201);\n  }\n  return res.sendStatus(422);\n}", "expect": ["truncation-before-inspection"], "reference": "Only the first 8192 bytes are scanned while the WHOLE payload is stored — pad the head with benign bytes and hide the malicious content in the tail to bypass the scanner."}
{"id": "sf08", "kind": "silent", "language": "yaml", "snippet": "# config.yaml as deployed\nscanner:\n  timeout_s: 30\nlogging:\n  level: info\n  enforce: true          # operator believes this turns on scanner enforcement\n\n# config.py\nclass ScannerCfg(BaseModel):\n    timeout_s: int = 30\n    enforce: bool = False\nclass LoggingCfg(BaseModel):\n    level: str = \"info\"\nclass Cfg(BaseModel):\n    scanner: ScannerCfg\n    logging: LoggingCfg", "expect": ["ignored-config-key"], "reference": "'enforce' is a field of ScannerCfg but is placed under 'logging' in the deployed config; the schema ignores the unknown key, so scanner enforcement silently stays at its default of False while the operator believes it is on."}
{"id": "sf09", "kind": "silent", "language": "python", "snippet": "# docs/configuration.md\n# | verify_signatures | bool | `true` | Artifact signatures are verified before install. |\n\n# installer/config.py\n@dataclass\nclass Config:\n    registry: str\n    verify_signatures: bool = False", "expect": ["doc-code-default-drift"], "reference": "The docs state verify_signatures defaults to true; the code defaults it to False — signature verification is off for everyone who does not set it explicitly, contradicting the documented default."}
{"id": "sf10", "kind": "silent", "language": "python", "snippet": "def export_audit_log(cur, dest: Path) -> None:\n    written = 0\n    with dest.open(\"w\") as fh:\n        for row in cur:\n            fh.write(json.dumps(row) + \"\\n\")\n            written += 1\n    print(\"Audit export complete: 50000 events written to\", dest)\n    # operators paste this line into the quarterly compliance evidence pack", "expect": ["hardcoded-report-value"], "reference": "The completion line prints the literal 50000 instead of the computed `written` count, so the number is wrong whenever the real row count differs — and operators copy it into compliance evidence."}
{"id": "sf11", "kind": "silent", "language": "dockerfile", "snippet": "# app/detect.py\nRULES_DIR = Path(__file__).parent / \"rules\"\ndef load():\n    if not RULES_DIR.exists():\n        return []                      # no rules -> detect() never matches\n    return [parse(p) for p in RULES_DIR.glob(\"*.yml\")]\n\n# Dockerfile (final stage)\nFROM python:3.13-slim\nCOPY --from=build /src/app/detect.py /app/detect.py\nCOPY --from=build /src/app/server.py /app/server.py\nENTRYPOINT [\"python\", \"/app/server.py\"]", "expect": ["shipped-artifact-gap"], "reference": "The Dockerfile copies only the .py files, not the rules/ directory, so in the built image RULES_DIR does not exist, load() returns [] and detection never matches. It works in a dev checkout and is dead in the image."}
{"id": "sf12", "kind": "silent", "language": "python", "snippet": "def test_search_blocks_sql_injection(client):\n    resp = client.get(\"/search\", params={\"q\": \"' OR 1=1--\"})\n    assert resp.status_code in (200, 400)\n    assert resp.elapsed.total_seconds() < 5\n\n# this is the only test naming SQL injection in the suite", "expect": ["vacuous-test"], "reference": "The assertion accepts both 200 and 400, so it passes whether or not the injection was blocked — the only SQL-injection test in the suite constrains nothing and would still pass against vulnerable code."}
{"id": "sf13", "kind": "silent", "language": "python", "snippet": "try:\n    import yara\n    HAS_YARA = True\nexcept ImportError:\n    HAS_YARA = False\n\n@pytest.mark.skipif(not HAS_YARA, reason=\"yara not installed\")\ndef test_malicious_upload_is_rejected(client):\n    resp = client.post(\"/upload\", files={\"f\": EICAR_BYTES})\n    assert resp.status_code == 422\n\n# CI installs the base extra only; the suite reports 0 failures", "expect": ["vacuous-test"], "reference": "yara is not installed in CI, so the test is always SKIPPED and the suite reports zero failures — the malicious-upload rejection is never actually exercised. The control is untested but looks covered."}
{"id": "sf14", "kind": "silent", "language": "go", "snippet": "func Authorize(ctx context.Context, principal, resource string) bool {\n\tallowed, err := policyEngine.Check(ctx, principal, resource)\n\tif err != nil {\n\t\tmetrics.PolicyCheckErrors.WithLabelValues(resource).Inc()\n\t\tlog.Error(\"policy check failed, denying\", \"resource\", resource, \"err\", err)\n\t\treturn false\n\t}\n\treturn allowed\n}", "expect": ["not-silent"], "reference": "NOT a silent failure: the error path denies (returns false) AND logs an error AND increments a metric — the degradation is loud and observable."}
{"id": "sf15", "kind": "silent", "language": "python", "snippet": "def load_waf(path: str) -> \"Waf\":\n    doc = yaml.safe_load(open(path)) or {}\n    rules = [compile_rule(r) for r in doc.get(\"rules\", [])]\n    if not rules:\n        raise ConfigError(f\"{path}: WAF enabled but 0 rules loaded; refusing to start\")\n    return Waf(rules)", "expect": ["not-silent"], "reference": "NOT a silent failure: a zero-rule config raises ConfigError and refuses to start, so the broken state is loud at deploy time rather than silently permissive."}
