# Silent-control-failure golden set — a control that LOOKS enabled and does nothing.
# Distinct from cases/audit*.jsonl: there is no classic vulnerability here. The code
# is not wrong, it is INERT — a broken system and a working one look identical from
# outside. Tests sota-code-security rules/10.
#
# 13 positive cases (one per hiding place) + 2 NEGATIVE controls (sf14/sf15) whose
# expect is ["not-silent"]: the control fails loudly, so flagging it is the error.
# The negatives exist because a model that answers "silent no-op" to everything
# would otherwise score 1.00. Languages are mixed on purpose (the breadth run
# showed domain/language effects are real).
{"id": "sf01", "kind": "silent", "language": "python", "snippet": "class MalwareScanner:\n    def __init__(self, model_dir: Path):\n        # model_dir is populated by an init container at boot\n        self.enabled = model_dir.is_dir()\n        self.model_dir = model_dir\n\n    def scan(self, blob: bytes) -> list[str]:\n        if not self.enabled:\n            return []\n        return _predict(self.model_dir, blob)\n\n# startup: log.info('scanner ENABLED=%s', scanner.enabled)", "expect": ["weak-existence-check"], "reference": "Presence/enablement is decided by model_dir.is_dir() — an empty or partially-populated directory sets enabled=True, so scan() reports no findings while looking enabled. The check must assert on the loaded artifact, not the path."}
{"id": "sf02", "kind": "silent", "language": "python", "snippet": "try:\n    import clamd\nexcept ImportError:\n    clamd = None\n\ndef scan_upload(data: bytes) -> dict:\n    if clamd is None:\n        return {\"clean\": True}\n    return clamd.ClamdUnixSocket().instream(io.BytesIO(data))\n\n# pyproject.toml: clamd is under [project.optional-dependencies].dev\n# Dockerfile: RUN pip install --no-cache-dir .", "expect": ["optional-dependency-degradation"], "reference": "clamd is an OPTIONAL dependency absent from the shipped image (it is a dev extra), so scan_upload returns {'clean': True} for every upload — the malware scan silently never runs and 'clean' is indistinguishable from a real clean scan."}
{"id": "sf03", "kind": "silent", "language": "python", "snippet": "def load_waf(path: str) -> \"Waf\":\n    doc = yaml.safe_load(open(path)) or {}\n    rules = [compile_rule(r) for r in doc.get(\"rules\", [])]\n    log.info(\"WAF ENABLED with %d rules\", len(rules))\n    return Waf(rules)\n\nclass Waf:\n    def blocks(self, req) -> bool:\n        return any(r.match(req) for r in self.rules)\n\n# shipped config/waf.example.yaml contains only commented-out rules", "expect": ["empty-ruleset-loaded"], "reference": "A config with zero rules loads successfully and logs 'WAF ENABLED with 0 rules'; blocks() then returns False for everything. The shipped example config has only commented-out rules, so deploying it verbatim yields a WAF that blocks nothing."}
{"id": "sf04", "kind": "silent", "language": "go", "snippet": "func Authorize(ctx context.Context, principal, resource string) bool {\n\tallowed, err := policyEngine.Check(ctx, principal, resource)\n\tif err != nil {\n\t\treturn true // don't block traffic on a policy-engine blip\n\t}\n\treturn allowed\n}", "expect": ["swallowed-enforcement-exception"], "reference": "The policy-engine error path returns true (allow) — authorization fails OPEN, and nothing logs or meters it, so a permanently broken policy engine looks identical to a permissive policy."}
{"id": "sf05", "kind": "silent", "language": "python", "snippet": "# settings.py\nDEBUG = os.getenv(\"DEBUG\") == \"1\"\n\"\"\"DEBUG: enable verbose request logging and the /__stats endpoint.\"\"\"\n\n# webhooks.py\ndef handle(req):\n    if not settings.DEBUG:\n        verify_signature(req)\n    return process(req.json)", "expect": ["overloaded-flag"], "reference": "The DEBUG flag is documented as verbose logging + a stats endpoint, but it is also used to skip webhook signature verification — one boolean gating a security control it was never scoped to."}
{"id": "sf06", "kind": "silent", "language": "python", "snippet": "MAX_INSPECT = 1 << 20\n\ndef inspect(body: bytes) -> Verdict:\n    if not body or len(body) > MAX_INSPECT:\n        return Verdict.ALLOW\n    return dlp_engine.inspect(body)\n\n# called from the outbound-email path; body is attacker-influenced", "expect": ["early-return-bypass"], "reference": "The size/emptiness guard returns ALLOW before the DLP engine runs, and an attacker controls the body size — padding past MAX_INSPECT deliberately bypasses inspection entirely."}
{"id": "sf07", "kind": "silent", "language": "javascript", "snippet": "async function handleUpload(req, res) {\n  const payload = await readAll(req);\n  const verdict = await scanner.scan(payload.slice(0, 8192));\n  if (verdict.clean) {\n    await store(payload);            // the WHOLE payload is stored\n    return res.sendStatus(201);\n  }\n  return res.sendStatus(422);\n}", "expect": ["truncation-before-inspection"], "reference": "Only the first 8192 bytes are scanned while the WHOLE payload is stored — pad the head with benign bytes and hide the malicious content in the tail to bypass the scanner."}
{"id": "sf08", "kind": "silent", "language": "yaml", "snippet": "# config.yaml as deployed\nscanner:\n  timeout_s: 30\nlogging:\n  level: info\n  enforce: true          # operator believes this turns on scanner enforcement\n\n# config.py\nclass ScannerCfg(BaseModel):\n    timeout_s: int = 30\n    enforce: bool = False\nclass LoggingCfg(BaseModel):\n    level: str = \"info\"\nclass Cfg(BaseModel):\n    scanner: ScannerCfg\n    logging: LoggingCfg", "expect": ["ignored-config-key"], "reference": "'enforce' is a field of ScannerCfg but is placed under 'logging' in the deployed config; the schema ignores the unknown key, so scanner enforcement silently stays at its default of False while the operator believes it is on."}
{"id": "sf09", "kind": "silent", "language": "python", "snippet": "# docs/configuration.md\n# | verify_signatures | bool | `true` | Artifact signatures are verified before install. |\n\n# installer/config.py\n@dataclass\nclass Config:\n    registry: str\n    verify_signatures: bool = False", "expect": ["doc-code-default-drift"], "reference": "The docs state verify_signatures defaults to true; the code defaults it to False — signature verification is off for everyone who does not set it explicitly, contradicting the documented default."}
{"id": "sf10", "kind": "silent", "language": "python", "snippet": "def export_audit_log(cur, dest: Path) -> None:\n    written = 0\n    with dest.open(\"w\") as fh:\n        for row in cur:\n            fh.write(json.dumps(row) + \"\\n\")\n            written += 1\n    print(\"Audit export complete: 50000 events written to\", dest)\n    # operators paste this line into the quarterly compliance evidence pack", "expect": ["hardcoded-report-value"], "reference": "The completion line prints the literal 50000 instead of the computed `written` count, so the number is wrong whenever the real row count differs — and operators copy it into compliance evidence."}
{"id": "sf11", "kind": "silent", "language": "dockerfile", "snippet": "# app/detect.py\nRULES_DIR = Path(__file__).parent / \"rules\"\ndef load():\n    if not RULES_DIR.exists():\n        return []                      # no rules -> detect() never matches\n    return [parse(p) for p in RULES_DIR.glob(\"*.yml\")]\n\n# Dockerfile (final stage)\nFROM python:3.13-slim\nCOPY --from=build /src/app/detect.py /app/detect.py\nCOPY --from=build /src/app/server.py /app/server.py\nENTRYPOINT [\"python\", \"/app/server.py\"]", "expect": ["shipped-artifact-gap"], "reference": "The Dockerfile copies only the .py files, not the rules/ directory, so in the built image RULES_DIR does not exist, load() returns [] and detection never matches. It works in a dev checkout and is dead in the image."}
{"id": "sf12", "kind": "silent", "language": "python", "snippet": "def test_search_blocks_sql_injection(client):\n    resp = client.get(\"/search\", params={\"q\": \"' OR 1=1--\"})\n    assert resp.status_code in (200, 400)\n    assert resp.elapsed.total_seconds() < 5\n\n# this is the only test naming SQL injection in the suite", "expect": ["vacuous-test"], "reference": "The assertion accepts both 200 and 400, so it passes whether or not the injection was blocked — the only SQL-injection test in the suite constrains nothing and would still pass against vulnerable code."}
{"id": "sf13", "kind": "silent", "language": "python", "snippet": "try:\n    import yara\n    HAS_YARA = True\nexcept ImportError:\n    HAS_YARA = False\n\n@pytest.mark.skipif(not HAS_YARA, reason=\"yara not installed\")\ndef test_malicious_upload_is_rejected(client):\n    resp = client.post(\"/upload\", files={\"f\": EICAR_BYTES})\n    assert resp.status_code == 422\n\n# CI installs the base extra only; the suite reports 0 failures", "expect": ["vacuous-test"], "reference": "yara is not installed in CI, so the test is always SKIPPED and the suite reports zero failures — the malicious-upload rejection is never actually exercised. The control is untested but looks covered."}
{"id": "sf14", "kind": "silent", "language": "go", "snippet": "func Authorize(ctx context.Context, principal, resource string) bool {\n\tallowed, err := policyEngine.Check(ctx, principal, resource)\n\tif err != nil {\n\t\tmetrics.PolicyCheckErrors.WithLabelValues(resource).Inc()\n\t\tlog.Error(\"policy check failed, denying\", \"resource\", resource, \"err\", err)\n\t\treturn false\n\t}\n\treturn allowed\n}", "expect": ["not-silent"], "reference": "NOT a silent failure: the error path denies (returns false) AND logs an error AND increments a metric — the degradation is loud and observable."}
{"id": "sf15", "kind": "silent", "language": "python", "snippet": "def load_waf(path: str) -> \"Waf\":\n    doc = yaml.safe_load(open(path)) or {}\n    rules = [compile_rule(r) for r in doc.get(\"rules\", [])]\n    if not rules:\n        raise ConfigError(f\"{path}: WAF enabled but 0 rules loaded; refusing to start\")\n    return Waf(rules)", "expect": ["not-silent"], "reference": "NOT a silent failure: a zero-rule config raises ConfigError and refuses to start, so the broken state is loud at deploy time rather than silently permissive."}
{"id": "sf16", "kind": "silent", "language": "python", "snippet": "MTLS_CERT = Path(\"/etc/certs/client.pem\")\n\ndef build_session() -> requests.Session:\n    s = requests.Session()\n    if MTLS_CERT.exists():\n        s.cert = str(MTLS_CERT)\n    return s\n\n# the cert is projected by a secret mount that is empty until the CSR is approved", "expect": ["weak-existence-check"], "reference": "MTLS_CERT.exists() is true for a zero-byte or not-yet-populated mounted file, so the session is built WITHOUT a usable client cert and falls back to unauthenticated TLS instead of failing; presence of the path is not proof of a usable credential."}
{"id": "sf17", "kind": "silent", "language": "javascript", "snippet": "let helmet;\ntry { helmet = require(\"helmet\"); } catch { helmet = null; }\n\nconst app = express();\nif (helmet) app.use(helmet());\napp.use(routes);\n\n// package.json lists helmet under devDependencies; the image runs `npm ci --omit=dev`", "expect": ["optional-dependency-degradation"], "reference": "helmet is a devDependency and is absent from the production install, so the security-headers middleware is silently skipped in production only — the app starts normally and serves every response without CSP/HSTS/frame protection."}
{"id": "sf18", "kind": "silent", "language": "go", "snippet": "//go:build !release\n\npackage audit\n\nfunc Emit(e Event) { sink.Write(e) }\n\n// audit_stub.go\n//go:build release\n\npackage audit\n\nfunc Emit(e Event) {}   // no-op in release builds", "expect": ["optional-dependency-degradation"], "reference": "The release build tag selects a no-op Emit, so audit events are silently discarded in exactly the builds that ship to production, while every caller and every test on the default build tag sees a working audit trail."}
{"id": "sf19", "kind": "silent", "language": "python", "snippet": "RULES = list(Path(\"/etc/detect/rules\").glob(\"*.yaml\"))\nENGINE = Engine([parse(p) for p in RULES])\n\ndef detect(ev) -> bool:\n    return ENGINE.matches(ev)\n\n# the rules package ships files named threat-*.yml", "expect": ["empty-ruleset-loaded"], "reference": "The glob pattern is *.yaml but the shipped rule files end in .yml, so RULES is empty, the engine holds zero rules and detect() returns False for every event while the service reports healthy."}
{"id": "sf20", "kind": "silent", "language": "python", "snippet": "def active_rules(all_rules, env: str):\n    return [r for r in all_rules if r.env == env]\n\nengine = Engine(active_rules(load_all(), os.getenv(\"APP_ENV\", \"production\")))\nlog.info(\"policy engine ready: %d rules\", len(engine.rules))\n\n# every shipped rule declares env: prod", "expect": ["empty-ruleset-loaded"], "reference": "The rules declare env 'prod' but APP_ENV defaults to 'production', so the filter matches nothing, the engine is constructed with zero rules and evaluates every request as unmatched (allowed) while logging that it is ready."}
{"id": "sf21", "kind": "silent", "language": "javascript", "snippet": "const allowed = await authz\n  .can(user, \"delete\", doc)\n  .catch(() => true);\n\nif (!allowed) return res.sendStatus(403);\nawait doc.delete();", "expect": ["swallowed-enforcement-exception"], "reference": "The .catch(() => true) turns any authorization error into an allow — the check fails open and nothing logs or meters it, so an authz service that is permanently down is indistinguishable from one that grants everything."}
{"id": "sf22", "kind": "silent", "language": "python", "snippet": "def check_rate_limit(key: str) -> bool:\n    with contextlib.suppress(Exception):\n        count = redis.incr(key)\n        redis.expire(key, 60)\n        return count <= LIMIT\n    return True", "expect": ["swallowed-enforcement-exception"], "reference": "contextlib.suppress swallows any Redis failure and the function then returns True (allowed), so when Redis is unreachable the rate limiter silently permits unlimited requests with no log or metric."}
{"id": "sf23", "kind": "silent", "language": "python", "snippet": "class BaseConfig:\n    TESTING = False\n    WTF_CSRF_ENABLED = not TESTING\n    RATELIMIT_ENABLED = not TESTING\n\nclass ProdConfig(BaseConfig):\n    TESTING = True   # set so the vendor SDK uses its lightweight client", "expect": ["overloaded-flag"], "reference": "WTF_CSRF_ENABLED and RATELIMIT_ENABLED are computed from TESTING at class-definition time in the base class, and ProdConfig re-uses TESTING for an unrelated SDK behaviour — in production CSRF protection and rate limiting are both disabled by a flag that was never scoped to security."}
{"id": "sf24", "kind": "silent", "language": "python", "snippet": "def scan_request(req) -> Verdict:\n    if req.headers.get(\"content-type\") != \"application/json\":\n        return Verdict.ALLOW\n    return waf.inspect(req.body)", "expect": ["early-return-bypass"], "reference": "Anything with a content-type other than application/json skips the WAF entirely, and the attacker controls that header — sending the same payload as text/plain or with no content-type bypasses inspection."}
{"id": "sf25", "kind": "silent", "language": "go", "snippet": "func Inspect(r *http.Request) Verdict {\n\tip := net.ParseIP(clientIP(r))\n\tif ip != nil && ip.IsPrivate() {\n\t\treturn Allow // internal traffic is trusted\n\t}\n\treturn dlp.Inspect(r.Body)\n}", "expect": ["early-return-bypass"], "reference": "Any request that appears to originate from a private IP skips DLP inspection; a server-side request forgery, a misconfigured proxy, or any compromised internal host therefore bypasses the control entirely, and network position is being used as identity."}
{"id": "sf26", "kind": "silent", "language": "python", "snippet": "def find_secrets(line: str) -> list[str]:\n    return SECRET_RE.findall(line[:1024])\n\nfor line in log_stream:\n    if find_secrets(line):\n        alert(line)", "expect": ["truncation-before-inspection"], "reference": "Only the first 1024 characters of each log line are scanned for secrets, so any secret emitted beyond that offset (common in long structured log lines) is never detected while the scanner reports clean."}
{"id": "sf27", "kind": "silent", "language": "sql", "snippet": "-- schema.sql (MySQL, non-strict sql_mode as deployed)\nCREATE TABLE api_keys (\n  id      BIGINT PRIMARY KEY,\n  key_hash CHAR(32) NOT NULL      -- was sized for md5, now stores sha256 hex\n);\n\n-- app.py\ndb.execute(\"INSERT INTO api_keys VALUES (%s, %s)\", (kid, hashlib.sha256(k).hexdigest()))", "expect": ["truncation-before-inspection"], "reference": "The sha256 hex digest is 64 characters but the column is CHAR(32), and in non-strict mode MySQL silently truncates on insert — every stored hash keeps only its first half, so comparison still succeeds and the effective key strength is halved without any error."}
{"id": "sf28", "kind": "silent", "language": "yaml", "snippet": "# deployment.yaml\nenv:\n  - name: ENFORCE_MTLS\n    value: \"true\"\n\n# server.py\nENFORCE = os.getenv(\"MTLS_ENFORCE\", \"false\").lower() == \"true\"\nif ENFORCE:\n    ctx.verify_mode = ssl.CERT_REQUIRED", "expect": ["ignored-config-key"], "reference": "The deployment sets ENFORCE_MTLS but the code reads MTLS_ENFORCE, so the variable never matches, ENFORCE stays False and client-certificate verification is off while the manifest asserts it is on."}
{"id": "sf29", "kind": "silent", "language": "yaml", "snippet": "# values.yaml supplied at install time\nnetworkPolicy:\n  enabled: true\n\n# templates/networkpolicy.yaml\n{{- if .Values.networkPolicies.enabled }}\napiVersion: networking.k8s.io/v1\nkind: NetworkPolicy\n...\n{{- end }}", "expect": ["ignored-config-key"], "reference": "The chart template reads .Values.networkPolicies.enabled (plural) while the supplied values set networkPolicy.enabled (singular); the missing key evaluates as false, Helm renders nothing, and the release installs with no NetworkPolicy at all without any error."}
{"id": "sf30", "kind": "silent", "language": "markdown", "snippet": "<!-- README.md -->\nRate limiting is enabled by default (60 requests/minute per API key).\n\n# app/limits.py\ndef install(app, cfg):\n    if cfg.get(\"rate_limit\", {}).get(\"enabled\"):\n        app.add_middleware(RateLimit, rpm=cfg[\"rate_limit\"].get(\"rpm\", 60))", "expect": ["doc-code-default-drift"], "reference": "The README states rate limiting is on by default, but the middleware installs only when rate_limit.enabled is explicitly truthy in config; every deployment that does not set it runs with no rate limiting despite the documented default."}
{"id": "sf31", "kind": "silent", "language": "python", "snippet": "# docs/privacy.md\n# Usage analytics are opt-in and disabled unless you set telemetry.enabled.\n\n# client/__init__.py\nclass Settings(BaseModel):\n    telemetry_enabled: bool = True\n    telemetry_endpoint: str = \"https://collect.example.net/v1/events\"", "expect": ["doc-code-default-drift"], "reference": "The documentation promises telemetry is opt-in and off by default, but the code defaults telemetry_enabled to True and ships a live collection endpoint — the drift runs in the dangerous direction, silently sending data the docs say is not sent."}
{"id": "sf32", "kind": "silent", "language": "python", "snippet": "issues = run_linters(paths)\nwrite_sarif(issues, \"results.sarif\")\nprint(f\"Security gate: PASSED — 0 findings across {len(paths)} files\")\nsys.exit(0)", "expect": ["hardcoded-report-value"], "reference": "The summary line prints '0 findings' as a literal and the process always exits 0 regardless of what run_linters returned, so the gate reports a pass even when the SARIF file it just wrote contains findings."}
{"id": "sf33", "kind": "silent", "language": "python", "snippet": "# setup.cfg\n[options]\npackages = find:\ninclude_package_data = False\n\n# MANIFEST.in\ninclude policies/*.rego\n\n# authz.py\nPOLICY_DIR = importlib.resources.files(\"app\") / \"policies\"\ndef load(): return [p.read_text() for p in POLICY_DIR.glob(\"*.rego\")] if POLICY_DIR.is_dir() else []", "expect": ["shipped-artifact-gap"], "reference": "MANIFEST.in affects the sdist only and include_package_data is False, so the wheel installed in production contains no policies/ directory; POLICY_DIR.is_dir() is False, load() returns an empty policy list and authorization evaluates against nothing."}
{"id": "sf34", "kind": "silent", "language": "go", "snippet": "//go:embed rules/*.yml\nvar rulesFS embed.FS\n\nfunc Load() []Rule {\n\tents, err := rulesFS.ReadDir(\"rules\")\n\tif err != nil {\n\t\treturn nil\n\t}\n\treturn parseAll(ents)\n}\n// the repository stores its rules in detection/rules/", "expect": ["shipped-artifact-gap"], "reference": "The embed pattern points at rules/ relative to the package but the rules live in detection/rules/, so the embedded filesystem is empty, ReadDir errors, Load returns nil and the detector runs with zero rules — the binary builds and starts cleanly."}
{"id": "sf35", "kind": "silent", "language": "python", "snippet": "def test_admin_endpoint_requires_auth(client, mock_authz):\n    client.get(\"/admin/users\")\n    mock_authz.assert_called_once", "expect": ["vacuous-test"], "reference": "assert_called_once is referenced without parentheses, so it is an attribute access on a MagicMock that is always truthy and never asserts anything; the test passes even if the endpoint performs no authorization call at all."}
{"id": "sf36", "kind": "silent", "language": "python", "snippet": "def test_path_traversal_blocked(tmp_path, client):\n    try:\n        resp = client.get(\"/files\", params={\"p\": \"../../etc/passwd\"})\n        assert resp.status_code == 403\n    except Exception:\n        pass", "expect": ["vacuous-test"], "reference": "The assertion is inside a try/except that swallows every exception including AssertionError, so the test reports success whether the traversal is blocked, allowed, or raises — it cannot fail."}
{"id": "sf37", "kind": "silent", "language": "typescript", "snippet": "it(\"rejects an expired token\", async () => {\n  const res = verifyToken(expiredJwt);\n  expect(res).rejects.toThrow();\n});", "expect": ["vacuous-test"], "reference": "The returned assertion promise is neither awaited nor returned, so Jest/Vitest finishes the test before the expectation settles; the test passes even when verifyToken resolves successfully for an expired token."}
{"id": "sf38", "kind": "silent", "language": "python", "snippet": "BLOCKED = re.compile(r\"^(SELECT|UNION|DROP)\\b\")\n\ndef is_blocked(q: str) -> bool:\n    return bool(BLOCKED.match(q))\n\n# queries arrive lowercased by the upstream normalizer", "expect": ["regex-never-matches"], "reference": "The pattern is case-sensitive and anchored while every query has already been lowercased upstream, so BLOCKED never matches any input — the blocklist is present, compiled, and permanently inert.", "novel": true}
{"id": "sf39", "kind": "silent", "language": "python", "snippet": "async def is_authorized(user, doc) -> bool: ...\n\nasync def handler(req):\n    if not is_authorized(req.user, req.doc):\n        raise HTTPException(403)\n    return await render(req.doc)", "expect": ["unawaited-async-check"], "reference": "is_authorized is a coroutine function called without await, so the condition tests a coroutine object which is always truthy — 'not coroutine' is always False and the 403 branch is unreachable, authorizing every request.", "novel": true}
{"id": "sf40", "kind": "silent", "language": "python", "snippet": "@require_admin\n@app.route(\"/admin/purge\", methods=[\"POST\"])\ndef purge():\n    db.purge_all()\n    return \"ok\"", "expect": ["decorator-order-bypass"], "reference": "The decorators are in the wrong order: app.route registers the undecorated purge function with Flask first, and require_admin then wraps only the local name — requests routed by the framework reach the unprotected function, so the admin check never runs.", "novel": true}
{"id": "sf41", "kind": "silent", "language": "python", "snippet": "cfg = load_yaml(\"/etc/app/config.yaml\")   # sets session_cookie_secure: true\ncfg.update(load_yaml(\"/etc/app/defaults.yaml\"))\napp.config.update(cfg)\n\n# defaults.yaml is the vendor-shipped file and contains session_cookie_secure: false", "expect": ["setting-overwritten"], "reference": "The merge precedence is inverted — defaults are applied on top of the operator's configuration, so the vendor default overwrites session_cookie_secure back to false and the explicitly configured secure-cookie setting is silently discarded.", "novel": true}
{"id": "sf42", "kind": "silent", "language": "go", "snippet": "ctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\ndefer cancel()\n\nreq, _ := http.NewRequest(\"GET\", target, nil)\nresp, err := client.Do(req)", "expect": ["timeout-not-applied"], "reference": "The timeout context is created but never attached to the request (no NewRequestWithContext or req.WithContext), so client.Do runs with no deadline — the timeout exists in the code, is visible in review, and constrains nothing.", "novel": true}
{"id": "sf43", "kind": "silent", "language": "python", "snippet": "for attempt in range(3):\n    try:\n        quarantine(upload_id)\n        break\n    except QuarantineError:\n        time.sleep(2 ** attempt)\n\nreturn {\"status\": \"processed\"}", "expect": ["retry-swallows-failure"], "reference": "After three failed quarantine attempts the loop simply exits and the function returns status 'processed' — the final failure is never raised, logged, or surfaced, so an upload that was never quarantined is reported as successfully handled.", "novel": true}
{"id": "sf44", "kind": "silent", "language": "go", "snippet": "cfg, err := LoadPolicies(path)\nif err != nil {\n\tlog.Fatalf(\"refusing to start: policy load failed: %v\", err)\n}\nengine := NewEngine(cfg)", "expect": ["not-silent"], "reference": "NOT a silent failure: a policy load error terminates startup with a fatal log, so a broken policy set is loud and immediate rather than silently permissive."}
{"id": "sf45", "kind": "silent", "language": "python", "snippet": "try:\n    verdict = scanner.scan(data)\nexcept ScannerUnavailable:\n    metrics.control_degraded.labels(\"scanner\", \"unavailable\").set(1)\n    log.warning(\"scanner unavailable — rejecting upload\", extra={\"upload\": uid})\n    raise HTTPException(503, \"upload scanning temporarily unavailable\")", "expect": ["not-silent"], "reference": "NOT a silent failure: when the scanner is unavailable the code sets a degradation gauge, logs a warning, and rejects the request with 503 — the control fails closed and every signal an operator needs is emitted."}
{"id": "sf46", "kind": "silent", "language": "javascript", "snippet": "const MAX_LOG = 512;\nconst verdict = await scanner.scan(payload);          // full payload scanned\nlogger.info(\"scan complete\", { sample: payload.slice(0, MAX_LOG), verdict });\nif (!verdict.clean) return res.sendStatus(422);", "expect": ["not-silent"], "reference": "NOT a silent failure: the full payload is scanned and the slice(0, MAX_LOG) truncation applies only to the log sample after the decision — truncating for display is correct and does not weaken the inspection."}
{"id": "sf47", "kind": "silent", "language": "python", "snippet": "def test_admin_endpoint_requires_auth(client):\n    resp = client.get(\"/admin/users\")\n    assert resp.status_code == 403\n    assert \"users\" not in resp.text", "expect": ["not-silent"], "reference": "NOT a silent failure: the test asserts a specific rejection status and that no data leaked, so it fails if authorization stops working — it is a genuine constraint, not a vacuous test."}
{"id": "sf48", "kind": "silent", "language": "python", "snippet": "# docs/runbook.md: \"If the policy engine is unreachable we FAIL OPEN by design\n# (availability outranks enforcement for this edge cache). Alert: PolicyEngineDown.\"\ntry:\n    allowed = policy.check(p, r)\nexcept PolicyUnavailable:\n    metrics.policy_fail_open.inc()\n    log.error(\"policy engine unreachable — failing open per runbook\")\n    allowed = True", "expect": ["not-silent"], "reference": "NOT a silent failure: this is a documented, deliberate fail-open — the behaviour is written down in the runbook, metered with a counter, logged at error level, and alerted on, so it is a design decision to review rather than an invisible bypass."}
{"id": "sf49", "kind": "silent", "language": "go", "snippet": "func Load() ([]Rule, error) {\n\trules, err := parseDir(dir)\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tif len(rules) == 0 {\n\t\treturn nil, fmt.Errorf(\"%s: 0 rules parsed, refusing to run unarmed\", dir)\n\t}\n\treturn rules, nil\n}", "expect": ["not-silent"], "reference": "NOT a silent failure: a zero-rule load is turned into an explicit error rather than an empty ruleset, so the unarmed state cannot reach production quietly."}
