{"id": "i1_k8s_deployment", "kind": "completeness", "task": "Write a Kubernetes Deployment manifest for a stateless web application container. Give me the YAML.", "skills": ["skills/sota-kubernetes/rules/03-admission-policy.md", "skills/sota-kubernetes/rules/06-workloads-tenancy.md", "skills/sota-sandboxing/rules/03-containers-microvms.md", "skills/sota-devsecops/rules/04-build-containers.md"], "rubric": [{"id": "nonroot", "c": "Runs as non-root (runAsNonRoot: true and/or a non-zero runAsUser)."}, {"id": "readonlyfs", "c": "readOnlyRootFilesystem: true is set."}, {"id": "dropcaps", "c": "Linux capabilities are dropped (drop: [ALL]) and privilege escalation disabled (allowPrivilegeEscalation: false)."}, {"id": "resources", "c": "CPU/memory requests AND limits are set."}, {"id": "pinnedimage", "c": "The image is pinned to a specific tag or digest \u2014 not :latest / untagged."}, {"id": "probes", "c": "Liveness AND readiness probes are defined."}, {"id": "noprivileged", "c": "The container is not privileged (privileged: false / absent) and no host namespaces."}, {"id": "seccomp", "c": "A seccompProfile (RuntimeDefault) is set."}, {"id": "secrets", "c": "No secrets are hardcoded inline \u2014 referenced via Secret/env-from, not plaintext."}, {"id": "availability", "c": "More than one replica and/or a PodDisruptionBudget / anti-affinity for availability."}]}
{"id": "i2_dockerfile", "kind": "completeness", "task": "Write a Dockerfile for a Python web service. Give me the Dockerfile.", "skills": ["skills/sota-devsecops/rules/04-build-containers.md", "skills/sota-sandboxing/rules/03-containers-microvms.md"], "rubric": [{"id": "nonroot", "c": "Creates and switches to a non-root USER before running the app."}, {"id": "pinnedbase", "c": "The base image is pinned to a specific version/digest \u2014 not python:latest."}, {"id": "multistage", "c": "Uses a multi-stage or slim/minimal build to reduce image size/attack surface."}, {"id": "nosecrets", "c": "No secrets/credentials are baked into layers (no COPY of .env, no ARG secrets persisted)."}, {"id": "minimalcopy", "c": "Copies only what's needed (uses .dockerignore or explicit COPY, not COPY . blindly)."}, {"id": "nocache", "c": "Package manager caches are cleaned / --no-cache-dir used (no leftover apt/pip cache)."}, {"id": "healthcheck", "c": "A HEALTHCHECK is defined."}, {"id": "pinneddeps", "c": "Dependencies are installed from a pinned lockfile/requirements, not unpinned latest."}, {"id": "workdir", "c": "A non-root-owned WORKDIR is used and file ownership is set for the app user."}, {"id": "noroot_ports", "c": "Does not require privileged (<1024) ports as root / exposes a high port."}]}
{"id": "i3_terraform_s3", "kind": "completeness", "task": "Write Terraform to create an AWS S3 bucket for storing user-uploaded files. Give me the code.", "skills": ["skills/sota-cloud-infrastructure/rules/02-iam-design.md", "skills/sota-cloud-infrastructure/rules/03-networking.md", "skills/sota-devsecops/rules/06-iac-deployment.md"], "rubric": [{"id": "blockpublic", "c": "aws_s3_bucket_public_access_block with all four settings true (no public access)."}, {"id": "encryption", "c": "Server-side encryption at rest is configured (SSE-KMS or SSE-S3)."}, {"id": "versioning", "c": "Bucket versioning is enabled."}, {"id": "tlsonly", "c": "A bucket policy denies non-TLS (aws:SecureTransport=false) access."}, {"id": "leastpriv", "c": "Any IAM policy is least-privilege (specific actions/resources), not wildcard s3:* on *."}, {"id": "logging", "c": "Access logging or CloudTrail data events are configured."}, {"id": "lifecycle", "c": "A lifecycle policy (expiration/transition/abort-incomplete-multipart) is defined."}, {"id": "nocreds", "c": "No hardcoded AWS credentials/secrets in the code."}, {"id": "ownership", "c": "Object ownership / ACLs disabled (BucketOwnerEnforced) rather than public ACLs."}, {"id": "tags", "c": "Resources are tagged."}]}
