# Frontend completeness golden set — the BREADTH arm of the competitor benchmark.
# Same design as completeness.jsonl (bare "build X" prompt, no cues; blind judge
# scores the artifact vs a fixed rubric of universal best practices) but a DIFFERENT
# task family: React frontend, not Python/FastAPI backend. Tests whether the library
# lift generalizes beyond backend. Rubric items are objective/checkable, not taste.
{"id": "f1_login_form", "kind": "completeness", "task": "Build a React login form component (email + password) that submits the credentials to an API. Give me the code.", "skills": ["skills/sota-web-frameworks/rules/02-react.md", "skills/sota-frontend-design/rules/04-ux-patterns.md", "skills/sota-frontend-design/rules/05-accessibility.md", "skills/sota-code-security/rules/05-web-security.md", "skills/sota-javascript-typescript/rules/05-security.md", "skills/sota-testing/rules/05-e2e-and-ui.md"], "rubric": [{"id": "controlled", "c": "Inputs are controlled (bound to React state via value + onChange), not uncontrolled/DOM-scraped."}, {"id": "validation", "c": "Client-side validation before submit (required fields, and email-format check)."}, {"id": "labels", "c": "Each input has an associated accessible <label> (htmlFor/id or wrapping label), not placeholder-only."}, {"id": "pwmask", "c": "The password field uses type=\"password\" (masked input)."}, {"id": "errorstate", "c": "Submit/validation errors are surfaced to the user in the UI (not only console)."}, {"id": "loadingstate", "c": "The submit button is disabled and/or a pending indicator is shown while the request is in flight."}, {"id": "nosecrets", "c": "No hardcoded API keys/tokens/secrets in the client component."}, {"id": "xss", "c": "No dangerouslySetInnerHTML with unsanitized/user data (relies on React's default escaping)."}, {"id": "nopwlog", "c": "The password is not logged to the console or otherwise persisted in plaintext client-side."}, {"id": "tests", "c": "A test for the component is included."}]}
{"id": "f2_data_table", "kind": "completeness", "task": "Build a React component that fetches a list of users from an API and shows them in a searchable table. Give me the code.", "skills": ["skills/sota-web-frameworks/rules/02-react.md", "skills/sota-web-frameworks/rules/03-nextjs.md", "skills/sota-frontend-design/rules/04-ux-patterns.md", "skills/sota-frontend-design/rules/05-accessibility.md", "skills/sota-code-security/rules/05-web-security.md", "skills/sota-testing/rules/05-e2e-and-ui.md"], "rubric": [{"id": "fetchloading", "c": "A loading state is shown while the data is being fetched."}, {"id": "errorstate", "c": "Fetch failures are caught and an error state is shown to the user."}, {"id": "emptystate", "c": "The empty / no-results case is explicitly handled (not a blank or broken UI)."}, {"id": "search", "c": "A controlled search/filter input actually filters the displayed rows."}, {"id": "semantictable", "c": "Data uses a semantic <table> (thead/tbody/th with scope) or an accessible equivalent, not divs only."}, {"id": "keys", "c": "Rows are rendered with stable React keys (a unique id key, not just the array index where an id exists)."}, {"id": "xss", "c": "Fetched API data is rendered via React escaping (no dangerouslySetInnerHTML of fetched data)."}, {"id": "cleanup", "c": "The fetch is aborted/cleaned up on unmount (AbortController or a cancel flag) to avoid setState-after-unmount."}, {"id": "bounded", "c": "The rendered list is bounded — paginated, virtualized, or limited — rather than rendering an unbounded dataset, or this is explicitly addressed."}, {"id": "tests", "c": "A test for the component is included."}]}
{"id": "f3_image_upload", "kind": "completeness", "task": "Build a React component that lets a user pick an image file and preview it before uploading it to an API. Give me the code.", "skills": ["skills/sota-web-frameworks/rules/02-react.md", "skills/sota-frontend-design/rules/04-ux-patterns.md", "skills/sota-frontend-design/rules/05-accessibility.md", "skills/sota-code-security/rules/05-web-security.md", "skills/sota-javascript-typescript/rules/05-security.md", "skills/sota-testing/rules/05-e2e-and-ui.md"], "rubric": [{"id": "accept", "c": "The file input restricts to images (accept=\"image/*\" or explicit types), not any file."}, {"id": "clientsize", "c": "A client-side max file-size check is enforced before upload."}, {"id": "typecheck", "c": "The selected file is validated as an image (type check), not trusted by name alone."}, {"id": "preview", "c": "A preview of the chosen image is shown before upload (e.g. via an object URL or FileReader)."}, {"id": "revoke", "c": "Any created object URL is revoked / FileReader cleaned up (no memory leak) on change/unmount."}, {"id": "loadingstate", "c": "An uploading/pending state (disabled control or progress) is shown during the request."}, {"id": "errorstate", "c": "Upload/validation errors are surfaced to the user in the UI."}, {"id": "label", "c": "The file input has an associated accessible label (not an unlabeled input)."}, {"id": "xss", "c": "The filename or any user-derived text is rendered safely (React escaping; no dangerouslySetInnerHTML)."}, {"id": "tests", "c": "A test for the component is included."}]}
