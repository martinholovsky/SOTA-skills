{"id": "cf1_auth_dashboard", "kind": "completeness", "task": "Build a Next.js (App Router) authenticated dashboard page \u2014 a server component that shows the logged-in user's account data. Give me the code.", "skills": ["skills/sota-web-frameworks/rules/03-nextjs.md", "skills/sota-web-frameworks/rules/06-ssr-hydration.md", "skills/sota-web-frameworks/rules/07-security.md", "skills/sota-code-security/rules/05-web-security.md", "skills/sota-code-security/rules/07-data-exposure.md", "skills/sota-testing/rules/05-e2e-and-ui.md"], "rubric": [{"id": "authserver", "c": "Authentication is checked server-side and unauthenticated users are redirected/blocked (not client-only)."}, {"id": "noleak", "c": "Server-only secrets (API keys, tokens, DB creds) are never passed to the client / serialized into props."}, {"id": "nosensitive", "c": "Only the fields needed are sent to the client \u2014 no over-fetching of sensitive user data into the bundle."}, {"id": "serverfetch", "c": "Data is fetched server-side (server component / no exposed credentials in client fetch)."}, {"id": "xss", "c": "User/content data is rendered via React escaping \u2014 no dangerouslySetInnerHTML of untrusted data."}, {"id": "headers", "c": "Security headers / CSP are set or explicitly addressed."}, {"id": "errloading", "c": "Error and loading states are handled (error.tsx/loading.tsx or try/catch + fallback)."}, {"id": "validation", "c": "Any route params / inputs are validated."}, {"id": "cache", "c": "Caching/revalidation of the authed data is handled correctly (no caching per-user private data publicly)."}, {"id": "tests", "c": "A test is included."}]}
{"id": "cf2_server_action", "kind": "completeness", "task": "Build a Next.js Server Action that updates the current user's profile (display name and bio). Give me the code.", "skills": ["skills/sota-web-frameworks/rules/03-nextjs.md", "skills/sota-web-frameworks/rules/06-ssr-hydration.md", "skills/sota-web-frameworks/rules/07-security.md", "skills/sota-code-security/rules/05-web-security.md", "skills/sota-code-security/rules/07-data-exposure.md", "skills/sota-testing/rules/05-e2e-and-ui.md"], "rubric": [{"id": "authserver", "c": "The action re-checks authentication server-side (does not trust the client)."}, {"id": "authz", "c": "Authorization: the user can only update their OWN profile; the user id comes from the session, not client input."}, {"id": "validation", "c": "Input is validated/sanitized server-side (lengths, types, allowed fields)."}, {"id": "massassign", "c": "Only the intended fields are updatable \u2014 no mass-assignment of client-supplied fields (e.g. role/id)."}, {"id": "revalidate", "c": "Cache is revalidated / UI updated after the mutation (revalidatePath/revalidateTag)."}, {"id": "errhandling", "c": "Errors are returned to the client safely (no internal details leaked)."}, {"id": "noleak", "c": "No secrets leaked to the client; server-only logic stays server-side."}, {"id": "xss", "c": "Stored values are rendered safely when displayed (escaping)."}, {"id": "csrf", "c": "Origin/CSRF considerations for the mutation are addressed (or noted as handled by the framework)."}, {"id": "tests", "c": "A test is included."}]}
{"id": "cf3_ssr_search", "kind": "completeness", "task": "Build a Next.js page (server-rendered) that lets a user search products by keyword and shows the matching results. Give me the code.", "skills": ["skills/sota-web-frameworks/rules/03-nextjs.md", "skills/sota-web-frameworks/rules/06-ssr-hydration.md", "skills/sota-web-frameworks/rules/07-security.md", "skills/sota-code-security/rules/05-web-security.md", "skills/sota-code-security/rules/07-data-exposure.md", "skills/sota-testing/rules/05-e2e-and-ui.md"], "rubric": [{"id": "serverfetch", "c": "Search is executed server-side; any API key/credential is never exposed to the client."}, {"id": "validation", "c": "The search query param is validated/bounded (length, allowed chars)."}, {"id": "injection", "c": "The query is built injection-safely (parameterized DB / properly encoded upstream call)."}, {"id": "xss", "c": "Result data is rendered via React escaping \u2014 no dangerouslySetInnerHTML of results."}, {"id": "states", "c": "Loading, empty (no results), and error states are handled."}, {"id": "hydration", "c": "No hydration mismatch risk (server/client render consistently; no Date.now()/random in render)."}, {"id": "bounded", "c": "Results are bounded/paginated, not unbounded."}, {"id": "abuse", "c": "Search abuse is considered (debounce/rate-limit/caching)."}, {"id": "headers", "c": "Security headers / CSP considered."}, {"id": "tests", "c": "A test is included."}]}
