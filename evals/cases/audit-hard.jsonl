# Harder audit golden set — multi-vuln + subtler cases meant to DISCRIMINATE
# (the base audit.jsonl saturates at 13/13). `expect` = every category that
# must be flagged; a partial catch (misses one of a multi-vuln) scores <1.
{"id": "ah01", "kind": "audit", "language": "python", "snippet": "name=request.args['name']; rows=db.execute(\"SELECT * FROM u WHERE name='\"+name+\"'\"); return \"<h1>Hello \"+name+\"</h1>\"", "expect": ["sql-injection", "xss"]}
{"id": "ah02", "kind": "audit", "language": "python", "snippet": "u = User(**request.get_json()); u.save()  # posted JSON may set is_admin=true", "expect": ["mass-assignment"]}
{"id": "ah03", "kind": "audit", "language": "python", "snippet": "charge_card(request.json['amount_cents'])  # amount comes from the client", "expect": ["business-logic-flaw"]}
{"id": "ah04", "kind": "audit", "language": "python", "snippet": "reset_token = str(random.random())[2:10]", "expect": ["insecure-random"]}
{"id": "ah05", "kind": "audit", "language": "python", "snippet": "log.info('login attempt user=' + request.args['user'])", "expect": ["log-injection"]}
{"id": "ah06", "kind": "audit", "language": "python", "snippet": "return redirect(request.args.get('next'))", "expect": ["open-redirect"]}
{"id": "ah07", "kind": "audit", "language": "python", "snippet": "return '<div class=bio>' + stored_user_bio + '</div>'  # bio is stored user input", "expect": ["xss"]}
{"id": "ah08", "kind": "audit", "language": "python", "snippet": "@app.get('/api/invoices/{inv_id}')\ndef get_invoice(inv_id: int, user=Depends(current_user)):\n    row = db.execute('SELECT * FROM invoices WHERE id = %s', (inv_id,)).fetchone()\n    return row", "expect": ["idor"]}
{"id": "ah09", "kind": "audit", "language": "python", "snippet": "def fetch(url):\n    host = urlparse(url).hostname\n    if host and host.endswith('example.com'):\n        return requests.get(url).text\n    raise ValueError('blocked')", "expect": ["ssrf"]}
{"id": "ah10", "kind": "audit", "language": "python", "snippet": "bal = db.get_balance(uid)\nif bal >= amount:\n    db.set_balance(uid, bal - amount)\n    ship(order)", "expect": ["business-logic-flaw"]}
{"id": "ah11", "kind": "audit", "language": "javascript", "snippet": "function merge(dst, src){ for (const k in src){ if (src[k] && typeof src[k]==='object'){ dst[k]=dst[k]||{}; merge(dst[k], src[k]); } else { dst[k]=src[k]; } } }\napp.post('/cfg', (req,res)=>{ merge(config, req.body); res.end(); });", "expect": ["prototype-pollution"]}
{"id": "ah12", "kind": "audit", "language": "python", "snippet": "@app.get('/export')\ndef export(name):\n    path = '/var/exports/' + name\n    os.system('tar czf /tmp/out.tgz ' + path)\n    return send_file('/tmp/out.tgz')", "expect": ["command-injection", "path-traversal"]}
{"id": "ah13", "kind": "audit", "language": "python", "snippet": "SECRET = 's3cr3t-hmac-key'\ndef valid(sig, body):\n    mac = hmac.new(SECRET.encode(), body, hashlib.sha256).hexdigest()\n    return sig == mac", "expect": ["hardcoded-secret", "non-constant-time-comparison"]}
{"id": "ah14", "kind": "audit", "language": "python", "snippet": "EMAIL = re.compile(r'^([a-zA-Z0-9]+)*@example\\.com$')\ndef valid_email(s):\n    return bool(EMAIL.match(s))", "expect": ["redos"]}
